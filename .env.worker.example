# Configurazione del worker PDF (docker-compose.worker.yml legge .env.worker).
# Non usare mai prefissi VITE_: questi valori non devono raggiungere il frontend.

# --- Obbligatorie -------------------------------------------------------------
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Almeno 32 caratteri, identico nelle Edge Function.
PDF_WORKER_CALLBACK_SECRET=

# --- Identità e versioni ------------------------------------------------------
PDF_WORKER_ID=production-eu-1
PDF_PIPELINE_VERSION=pdf-worker-v1
PDF_CHUNKING_VERSION=unified-v3

# --- Tuning coda --------------------------------------------------------------
PDF_WORKER_CONCURRENCY=1
PDF_WORKER_POLL_MS=1500
PDF_JOB_LEASE_SECONDS=180
# Must be well below lease (worker rejects heartbeatMs * 2 >= leaseSeconds * 1000).
PDF_WORKER_HEARTBEAT_MS=30000

# --- OCR e limiti -------------------------------------------------------------
PDF_OCR_LANGUAGES=ita+eng
PDF_OCR_MAX_PAGES_FREE=0
PDF_OCR_MAX_PAGES_BASE=24
PDF_OCR_MAX_PAGES_PREMIUM=160
PDF_MAX_UPLOAD_BYTES=52428800
PDF_MAX_PAGES=2000

# --- Healthcheck --------------------------------------------------------------
# 0 disattiva l'endpoint /healthz (sconsigliato in produzione).
PDF_WORKER_HEALTH_PORT=8080

# --- AI (necessarie per gli stage che generano flashcard/outline) --------------
DEEPSEEK_API_KEY=
