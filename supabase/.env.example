# ============================================================================
# Backend secrets — set with:  supabase secrets set --env-file supabase/.env
# NEVER commit real values. Nothing here is exposed to the browser.
# ============================================================================

# Supabase (SUPABASE_URL / SUPABASE_ANON_KEY are injected automatically in the
# Edge runtime; the service-role key must be set explicitly as a secret).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ALLOW_ORIGIN=https://unimidoc.it
CORS_ALLOW_ORIGINS=https://unimidoc.it,https://www.unimidoc.it,https://unimidoc.netlify.app,http://127.0.0.1:5173,http://localhost:5173

# Canonical public URLs and legal versions. Billing fails closed when identity,
# contact or versioned terms are missing.
LEGAL_ENTITY_NAME=
LEGAL_ENTITY_ADDRESS=
LEGAL_CONTACT_EMAIL=
LEGAL_VAT_ID=
LEGAL_TERMS_VERSION=2026-07-11
LEGAL_PRIVACY_VERSION=2026-07-11
LEGAL_SALES_VERSION=2026-07-11

# Stripe Billing / Checkout. Use test keys and Price IDs first; never expose
# any of these values through VITE_* variables.
BILLING_MODE=test
BILLING_APP_URL=https://unimidoc.netlify.app
BILLING_TERMS_VERSION=2026-07-11
BILLING_PRIVACY_VERSION=2026-07-11
BILLING_SALES_TERMS_VERSION=2026-07-11
BILLING_CONNECT_TERMS_VERSION=2026-07-11
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_TOPUP_STARTER=
STRIPE_PRICE_TOPUP_STANDARD=
STRIPE_PRICE_TOPUP_PLUS=
STRIPE_PRICE_TOPUP_MAX=
# Deliberately unsupported until merchant/tax review and tax-inclusive Price
# accounting are completed. Setting true keeps Checkout fail-closed.
STRIPE_AUTOMATIC_TAX_ENABLED=false
STRIPE_CONNECT_ENABLED=false
STRIPE_ACCOUNTS_V2_VERSION=2026-02-25.preview
SELLER_EARNING_HOLD_DAYS=14
SELLER_MIN_PAYOUT_CREDITS=250

# Dedicated Node/container PDF worker. These are server-only. The worker
# requires qpdf, Poppler, OCRmyPDF and Tesseract ita+eng in its runtime image.
PDF_PIPELINE_VERSION=pdf-worker-v1
PDF_WORKER_ENABLED=false
PDF_WORKER_ID=
PDF_WORKER_CALLBACK_SECRET=
PDF_WORKER_CONCURRENCY=2
PDF_WORKER_POLL_MS=1500
PDF_JOB_LEASE_SECONDS=120
PDF_OCR_LANGUAGES=ita+eng
PDF_MAX_PAGES=2000
PDF_MAX_TEMP_BYTES=1073741824
PDF_RAG_INDEX_TIMEOUT_MS=900000

# DeepSeek V4 Flash — ALL text intelligence
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Gemini — vision plus model-versioned document embeddings
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_DIMENSIONS=768
RAG_EMBEDDING_VERSION=1
GEMINI_INPUT_PRICE_PER_1M=0.50
GEMINI_OUTPUT_PRICE_PER_1M=3.00

# Versioned prompts (bump when you change wording)
AI_FLASHCARD_PROMPT_VERSION=flashcards_v2
AI_EXPLAIN_PROMPT_VERSION=explain_v1
AI_FOLLOWUP_PROMPT_VERSION=followup_v1
AI_EXAMPLE_PROMPT_VERSION=example_v1
AI_MEMO_PROMPT_VERSION=memo_v1
AI_VISUALIZE_PROMPT_VERSION=visualize_v1
AI_IMAGE_OCCLUSION_PROMPT_VERSION=image_occlusion_v2

# Limits / anti-abuse
AI_MAX_CALLS_PER_MINUTE=12
PREMIUM_MAX_EXPLAINS_PER_MONTH=1000
PREMIUM_MAX_FOLLOWUPS_PER_MONTH=500
PREMIUM_MAX_AI_HELPS_PER_MONTH=2000
PREMIUM_MAX_GEMINI_VISION_CALLS_PER_MONTH=300
AI_MAX_SOURCE_CHARS_EXPLAIN=6000
AI_EXPLAIN_MAX_TOKENS=900
AI_FOLLOWUP_MAX_TOKENS=900
MAX_OCCLUSION_MASKS_PER_CARD=20
MAX_HIGHLIGHT_SELECTION_CHARS=8000
MAX_IMAGE_BASE64_CHARS=12000000
AI_MAX_CARDS_PER_GENERATION=40
RAG_MAX_QUERIES_FREE_PER_MONTH=30
RAG_MAX_QUERIES_PREMIUM_PER_MONTH=1000
RAG_MAX_INDEX_RUNS_PER_MONTH=60

# ============================================================================
# Frontend (Vite) — safe to expose. Copy into the project root .env.local
# ============================================================================
VITE_SUPABASE_URL=
VITE_DOCUMENT_UPLOAD_ENABLED=false
VITE_SUPABASE_ANON_KEY=
VITE_BILLING_ENABLED=false
VITE_LEGAL_ENTITY_NAME=
VITE_LEGAL_ENTITY_ADDRESS=
VITE_LEGAL_CONTACT_EMAIL=
VITE_LEGAL_VAT_ID=
FREE_FLASHCARD_LIMIT=15
FREE_QUIZ_LIMIT=10
