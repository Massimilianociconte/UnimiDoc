{
  "name": "unimidoc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/fetch-ocr-assets.mjs && tsc -b && vite build && node scripts/prerender.mjs",
    "fetch:ocr": "node scripts/fetch-ocr-assets.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:functions": "cd supabase/functions && deno check */index.ts",
    "test:functions": "cd supabase/functions && deno test --allow-env _shared/",
    "test:db": "supabase test db",
    "e2e": "playwright test",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "worker:pdf": "tsx server/pdf-pipeline/worker.ts",
    "worker:pdf:once": "tsx server/pdf-pipeline/worker.ts --once",
    "worker:pdf:reconcile": "tsx scripts/reconcile-pdf-jobs.ts",
    "gc:storage": "tsx scripts/gc-storage.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tesseract.js": "^5.1.1",
    "tsx": "4.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.2.6"
  }
}
